{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "description": "User's email address" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"], "description": "User's role in the platform" },
        "points": { "type": "number", "description": "Total points earned by the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "A collection of modules and lessons",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Course title" },
        "description": { "type": "string", "description": "Course description" },
        "thumbnail": { "type": "string", "description": "Course thumbnail URL" },
        "level": { "type": "string", "enum": ["beginner", "intermediate", "advanced"], "description": "Difficulty level" },
        "duration": { "type": "string", "description": "Estimated duration (e.g., '4 weeks')" },
        "teacherId": { "type": "string", "description": "UID of the teacher" },
        "rating": { "type": "number", "description": "Average rating" },
        "enrolledCount": { "type": "number", "description": "Number of students enrolled" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "level", "teacherId"]
    },
    "Module": {
      "title": "Module",
      "description": "A unit within a course",
      "type": "object",
      "properties": {
        "courseId": { "type": "string", "description": "ID of the parent course" },
        "title": { "type": "string", "description": "Module title" },
        "order": { "type": "number", "description": "Order within the course" }
      },
      "required": ["courseId", "title", "order"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Educational content for Arabic learning",
      "type": "object",
      "properties": {
        "courseId": { "type": "string", "description": "ID of the parent course" },
        "moduleId": { "type": "string", "description": "ID of the parent module" },
        "title": { "type": "string", "description": "Lesson title" },
        "content": { "type": "string", "description": "Markdown content or video URL" },
        "type": { "type": "string", "enum": ["text", "video"], "description": "Type of lesson content" },
        "order": { "type": "number", "description": "Order within the module" }
      },
      "required": ["courseId", "moduleId", "title", "content", "type", "order"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Student's progress in a course",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the student" },
        "courseId": { "type": "string", "description": "ID of the course" },
        "progress": { "type": "number", "description": "Percentage of completion (0-100)" },
        "completedLessons": { "type": "array", "description": "List of completed lesson IDs" },
        "status": { "type": "string", "enum": ["enrolled", "completed"] },
        "enrolledAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId", "progress", "status"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Course completion certificate",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "studentName": { "type": "string" },
        "courseTitle": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "certificateId": { "type": "string" }
      },
      "required": ["userId", "courseId", "studentName", "courseTitle", "issueDate", "certificateId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Course reviews and comments",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "userId", "text", "createdAt"]
    },
    "QuizAttempt": {
      "title": "Quiz Attempt",
      "description": "Data from a student's quiz attempt",
      "type": "object",
      "properties": {
        "studentData": {
          "type": "object",
          "properties": {
            "firstName": { "type": "string" },
            "lastName": { "type": "string" },
            "level": { "type": "string" },
            "section": { "type": "string" },
            "number": { "type": "string" }
          }
        },
        "quizType": { "type": "string" },
        "quizId": { "type": "string" },
        "score": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentData", "quizType", "score", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/courses/{courseId}": { "schema": "Course", "description": "Courses" },
    "/courses/{courseId}/modules/{moduleId}": { "schema": "Module", "description": "Modules within a course" },
    "/courses/{courseId}/modules/{moduleId}/lessons/{lessonId}": { "schema": "Lesson", "description": "Lessons within a module" },
    "/enrollments/{enrollmentId}": { "schema": "Enrollment", "description": "Student enrollments" },
    "/certificates/{certificateId}": { "schema": "Certificate", "description": "Issued certificates" },
    "/comments/{commentId}": { "schema": "Comment", "description": "Course comments" },
    "/quizAttempts/{attemptId}": { "schema": "QuizAttempt", "description": "Quiz attempts and results" }
  }
}
