{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "description": "User's email address" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"], "description": "User's role in the platform" },
        "points": { "type": "number", "description": "Total points earned by the user" },
        "progress": { "type": "object", "description": "Map of lesson IDs to completion status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Educational content for Arabic learning",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Lesson title" },
        "content": { "type": "string", "description": "Markdown content or video URL" },
        "type": { "type": "string", "enum": ["text", "video"], "description": "Type of lesson content" },
        "category": { "type": "string", "enum": ["grammar", "vocabulary", "spelling", "other"], "description": "Lesson category (نحو، صرف، إملاء...)" },
        "level": { "type": "string", "enum": ["beginner", "intermediate", "advanced"], "description": "Difficulty level" },
        "order": { "type": "number", "description": "Order of the lesson in the curriculum" },
        "teacherId": { "type": "string", "description": "UID of the teacher who created the lesson" }
      },
      "required": ["title", "content", "type", "category", "level"]
    },
    "Exercise": {
      "title": "Exercise",
      "description": "Interactive quiz questions",
      "type": "object",
      "properties": {
        "lessonId": { "type": "string", "description": "ID of the associated lesson" },
        "question": { "type": "string", "description": "The question text" },
        "options": { "type": "array", "description": "List of possible answers" },
        "correctAnswer": { "type": "number", "description": "Index of the correct answer in the options array" },
        "points": { "type": "number", "description": "Points awarded for correct answer" }
      },
      "required": ["question", "options", "correctAnswer", "points"]
    },
    "LiveSession": {
      "title": "Live Session",
      "description": "Information about scheduled live classes",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Session title" },
        "startTime": { "type": "string", "format": "date-time", "description": "Scheduled start time" },
        "meetingUrl": { "type": "string", "description": "Google Meet or Jitsi link" },
        "status": { "type": "string", "enum": ["scheduled", "live", "ended"], "description": "Current status of the session" },
        "teacherId": { "type": "string", "description": "UID of the teacher conducting the session" }
      },
      "required": ["title", "startTime", "meetingUrl", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/lessons/{lessonId}": { "schema": "Lesson", "description": "Educational lessons" },
    "/lessons/{lessonId}/exercises/{exerciseId}": { "schema": "Exercise", "description": "Exercises for a specific lesson" },
    "/liveSessions/{sessionId}": { "schema": "LiveSession", "description": "Live class sessions" }
  }
}
